# ╔══════════════════════════════════════════════════════╗
# ║  FinAI — Environment Variables Template              ║
# ║  Copy to: backend/.env and frontend/.env.local       ║
# ╚══════════════════════════════════════════════════════╝

# ── backend/.env ───────────────────────────────────────
APP_NAME=FinAI
APP_VERSION=9.0.0
DEBUG=false

# PostgreSQL (update host/user/pass to match your setup)
DATABASE_URL=postgresql+asyncpg://finai_user:finai_pass@localhost:5432/finai_db
DATABASE_URL_SYNC=postgresql://finai_user:finai_pass@localhost:5432/finai_db

# CHANGE THIS in production! Use: openssl rand -hex 32
SECRET_KEY=finai-dev-secret-key-change-in-production-32chars

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# File uploads directory (relative to backend/)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ML Model configuration
ML_MODELS_DIR=../ml_models
FINBERT_MODEL=ProsusAI/finbert
WHISPER_MODEL=base
OCR_ENGINE=paddleocr

# ── frontend/.env.local ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
